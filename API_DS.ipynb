def parse_two_rankings(raw: str):
    """将原始交替文本解析为两个排名列表"""
    lines = [line.strip() for line in raw.strip().splitlines() if line.strip()]
    # 每4个元素为一组：左银行, 左数值, 右银行, 右数值
    left_banks, left_scores = [], []
    right_banks, right_scores = [], []
    for i in range(0, len(lines), 4):
        if i+3 >= len(lines):
            break
        left_banks.append(lines[i])
        left_scores.append(float(lines[i+1]))
        right_banks.append(lines[i+2])
        right_scores.append(float(lines[i+3]))
    # 合并为列表 of (银行, 分数)
    left_ranking = list(zip(left_banks, left_scores))
    right_ranking = list(zip(right_banks, right_scores))
    return left_ranking, right_ranking

left_rank, right_rank = parse_two_rankings(raw_text)

# 构造清晰的提示词（包含完整排名表）
prompt_template = """你是一个金融分析助手。请根据以下两家银行排名数据回答问题。

## 排名一（左列：机器排名 - Real_rank）
| 银行 | 得分 |
|------|------|
{left_table}

## 排名二（右列：sum / 另一机器排名）
| 银行 | 得分 |
|------|------|
{right_table}

现在请回答：{question}
"""

def build_prompt(question: str) -> str:
    # 生成Markdown表格行
    left_rows = "\n".join([f"| {bank} | {score:.2f} |" for bank, score in left_rank])
    right_rows = "\n".join([f"| {bank} | {score:.2f} |" for bank, score in right_rank])
    return prompt_template.format(left_table=left_rows, right_table=right_rows, question=question)

# 示例：用户要问的问题
user_question = "请列出两个排名中各自得分最高的前5家银行，并比较它们的差异。"

final_prompt = build_prompt(user_question)

